{
  "name": "LumenGuide",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "npm run build:md && vite",
    "build:md": "node scripts/build-md.mjs",
    "build": "npm run build:md && run-p type-check \"build-only {@}\" --",
    "preview": "vite preview",
    "build-only": "vite build",
    "type-check": "vue-tsc --build",
    "lint": "run-s lint:*",
    "lint:oxlint": "oxlint . --fix",
    "lint:eslint": "eslint . --fix --cache",
    "deploy": "gh-pages -d dist --repo git@github.com:xzhnew/LumenGuide.git"
  },
  "dependencies": {
    "@waline/client": "^3.15.2",
    "vue": "^3.5.32"
  },
  "devDependencies": {
    "@tsconfig/node24": "^24.0.4",
    "@types/node": "^24.12.2",
    "@vitejs/plugin-basic-ssl": "^2.3.0",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vue/eslint-config-typescript": "^14.7.0",
    "@vue/tsconfig": "^0.9.1",
    "eslint": "^10.2.1",
    "eslint-plugin-oxlint": "~1.60.0",
    "eslint-plugin-vue": "~10.8.0",
    "gh-pages": "^6.3.0",
    "gray-matter": "^4.0.3",
    "jiti": "^2.6.1",
    "markdown-it": "^14.3.0",
    "npm-run-all2": "^8.0.4",
    "oxlint": "~1.60.0",
    "playwright": "^1.61.1",
    "typescript": "~6.0.0",
    "vite": "^8.0.8",
    "vite-plugin-vue-devtools": "^8.1.1",
    "vue-tsc": "^3.2.6"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  }
}
